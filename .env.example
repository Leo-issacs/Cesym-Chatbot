# Google Drive
# ID de la carpeta donde están los Excels.
# Lo encontrás en la URL: drive.google.com/drive/folders/<DRIVE_FOLDER_ID>
# IMPORTANTE: comparte esa carpeta (permiso Editor) con el email de la
# Service Account: cesym-sync@cesym-hvac.iam.gserviceaccount.com
DRIVE_FOLDER_ID=

# ─── Autenticación con Drive: Service Account (recomendado en cloud) ──
#
# JSON COMPLETO de la Service Account, pegado tal cual (una sola línea o
# multilínea según lo permita el panel). Es el método preferido: no expira
# como el refresh token de OAuth y no requiere navegador.
# En Railway: pega aquí el contenido íntegro del archivo .json de la cuenta
#             cesym-sync@cesym-hvac.iam.gserviceaccount.com
# Acepta también el JSON en base64 si el panel reescapa los saltos de línea.
# NUNCA commitees el JSON: va SOLO como variable de entorno.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Ruta al archivo credentials.json de OAuth (solo fallback local, último recurso).
# Por defecto: .credentials/credentials.json (no hace falta cambiarlo)
# GOOGLE_CREDENTIALS_PATH=.credentials/credentials.json

# Claude API — fallback de lenguaje natural
# Obtené la clave en: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Seguridad del webhook de Twilio ──────────────────────────────
#
# Token de autenticación de tu cuenta Twilio (console.twilio.com → Account Info).
# Se usa para validar la firma X-Twilio-Signature de cada mensaje entrante.
# Sin esto, la validación de firma siempre falla (en log-only solo lo registra).
TWILIO_AUTH_TOKEN=

# Whitelist de números autorizados a operar el bot.
# Lista separada por comas. Acepta 'whatsapp:+521...' o solo '+521...'.
# Ejemplo: NUMEROS_AUTORIZADOS=whatsapp:+521234567890,+521555000111
# Si se deja vacío, NO se filtra a nadie (la whitelist queda abierta).
NUMEROS_AUTORIZADOS=

# Flags de aplicación de seguridad (modo "log only" por defecto = "0").
#   "0" → solo registra en los logs lo que NO pasaría la validación (no bloquea).
#   "1" → bloquea (responde 403) las peticiones que no pasan.
# Recomendado: dejar ambos en "0", observar los logs de Railway unos días para
# confirmar que NO se rechazarían mensajes legítimos, y recién entonces poner "1".
ENFORCE_TWILIO_SIGNATURE=0
ENFORCE_WHITELIST=0

# Credenciales Google Drive en base64 (para despliegue cloud)
# Generá los valores con: python scripts/export_credenciales.py
# GOOGLE_CREDENTIALS_JSON=
# GOOGLE_TOKEN_JSON=
