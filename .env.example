# ═══════════════════════════════════════════════════════════════════
#  .env.example — Cesym Chatbot
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env al repositorio (ya está en .gitignore).
# ═══════════════════════════════════════════════════════════════════

# ─── Base de datos PostgreSQL (v1 — Fase 1 migración) ─────────────
#
# URL de runtime del bot (lectura/escritura durante operación normal).
# Supabase: usa el Transaction Pooler, puerto 6543 (?pgbouncer=true al final).
# Railway:  usa la URL directa que Railway te da en la pestaña "Variables".
# Neon:     usa la URL con ?sslmode=require.
#
DATABASE_URL=postgresql://usuario:contraseña@host:5432/postgres

# URL directa para migraciones DDL (CREATE TABLE, Alembic).
# Supabase: cámbia el puerto a 5432 y quita ?pgbouncer=true.
# Railway/Neon: puede ser la misma que DATABASE_URL — ponla igual.
# Si no la defines, el script de migración usa DATABASE_URL para todo.
#
DATABASE_MIGRATION_URL=postgresql://usuario:contraseña@host:5432/postgres

# ─── Sesiones WhatsApp en Postgres ────────────────────────────────
#
# Por defecto "0" — las sesiones se siguen guardando en data/sesiones.json.
# Cambia a "1" SOLO después de ejecutar el script de migración y verificar
# que los conteos cuadren. Requiere que DATABASE_URL esté configurada.
#
USE_POSTGRES_SESSIONS=0

# ─── Google Drive ─────────────────────────────────────────────────
#
# ID de la carpeta donde están los Excels.
# Lo encontrás en la URL: drive.google.com/drive/folders/<DRIVE_FOLDER_ID>
#
DRIVE_FOLDER_ID=

# ID de la carpeta donde se suben los backups de Excel antes de modificarlos.
# Si no se define, los backups solo se guardan en data/backups/ (efímero en Railway).
#
DRIVE_BACKUPS_FOLDER_ID=

# ID de la carpeta donde se suben los reportes HTML/PDF generados.
#
DRIVE_REPORTS_FOLDER_ID=

# Ruta al archivo credentials.json de Google Cloud Console (desarrollo local).
# Por defecto: .credentials/credentials.json — no hace falta cambiarlo normalmente.
# GOOGLE_CREDENTIALS_PATH=.credentials/credentials.json

# Credenciales Google en base64 (para despliegue cloud — Railway/Render).
# Generá los valores con: python scripts/export_credenciales.py
#
# GOOGLE_CREDENTIALS_JSON=
# GOOGLE_TOKEN_JSON=

# ─── Twilio (WhatsApp) ────────────────────────────────────────────
#
# Credenciales de tu cuenta Twilio (console.twilio.com).
# TWILIO_ACCOUNT_SID y TWILIO_AUTH_TOKEN son necesarias para validar
# la firma del webhook (seguridad — ver plan v1, punto P0 #3).
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# Número de WhatsApp de Twilio (formato: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Números autorizados para operar el bot (whitelist de seguridad).
# Lista separada por comas, formato whatsapp:+521234567890.
# Si está vacío, cualquier número puede usar el bot (inseguro para producción).
# ALLOWED_WHATSAPP_NUMBERS=whatsapp:+521234567890,whatsapp:+521234567891

# ─── Claude API (fallback de lenguaje natural) ────────────────────
#
# Obtené la clave en: console.anthropic.com
#
ANTHROPIC_API_KEY=sk-ant-...

# ─── Configuración de sincronización ─────────────────────────────
#
# Intervalo en horas para la sincronización automática desde Drive.
# Default: 6 horas.
#
SYNC_INTERVALO_HORAS=6

# ─── Railway (se rellena automáticamente en producción) ───────────
#
# Railway inyecta estas variables en el entorno — no hace falta definirlas.
# Se listan aquí para documentar qué usa el código.
#
# RAILWAY_PUBLIC_DOMAIN=tu-app.up.railway.app
# PORT=8000
