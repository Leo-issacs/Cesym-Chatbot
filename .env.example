# ═══════════════════════════════════════════════════════════════════
#  .env.example — Cesym Chatbot
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env al repositorio (ya está en .gitignore).
# ═══════════════════════════════════════════════════════════════════

# ─── Base de datos PostgreSQL ──────────────────────────────────────
#
# URL de runtime del bot. Supabase: usa el Transaction Pooler (puerto 6543).
# Railway: usa la URL directa de la pestaña "Variables".
DATABASE_URL=postgresql://usuario:contraseña@host:6543/postgres

# URL directa para migraciones DDL (CREATE TABLE, Alembic).
# Supabase: puerto 5432 (sin pooler). Railway/Neon: puede ser la misma que DATABASE_URL.
DATABASE_MIGRATION_URL=postgresql://usuario:contraseña@host:5432/postgres

# Lectura de datos desde Postgres en lugar de Excel.
# "1" = lee desde las tablas chatbot.* de Postgres (DEFAULT desde PR-14).
# "0" = fuerza la lectura desde los archivos Excel.
# Si Postgres falla (sin DATABASE_URL o caída), cae a Excel automáticamente.
# Manténlo en "1" solo mientras el ETL deje los datos de Postgres al día
# (el refresco es manual: ver docs/DATA_FLOW.md §3).
USE_POSTGRES_READS=1

# Escritura dual de trabajos nuevos: Postgres (chatbot.trabajos) + Excel.
# "0" = solo Excel (default, comportamiento de hoy, sin cambio).
# "1" = escribe en Postgres primero y luego en Excel. Si Postgres falla, solo Excel.
# set to 1 to enable dual write PG+Excel
USE_POSTGRES_WRITES=0

# Sesiones WhatsApp en Postgres en lugar de data/sesiones.json.
# "0" = archivo local (default). "1" = tabla chatbot.sesiones_bot.
# Activar SOLO después de ejecutar el script de migración.
USE_POSTGRES_SESSIONS=0

# ─── Google Drive ─────────────────────────────────────────────────
#
# ID de la carpeta con los Excels.
# URL: drive.google.com/drive/folders/<DRIVE_FOLDER_ID>
# IMPORTANTE: comparte la carpeta (permiso Editor) con:
#   cesym-sync@cesym-hvac.iam.gserviceaccount.com
DRIVE_FOLDER_ID=

# Carpeta donde se suben los backups de Excel antes de modificarlos.
# Si no se define, los backups solo se guardan en data/backups/ (efímero en Railway).
DRIVE_BACKUPS_FOLDER_ID=

# Carpeta donde se suben los reportes HTML/PDF generados.
DRIVE_REPORTS_FOLDER_ID=

# ─── Autenticación con Drive: Service Account (recomendado en cloud) ──
#
# JSON COMPLETO de la Service Account (cesym-sync@cesym-hvac.iam.gserviceaccount.com).
# En Railway: pega el contenido íntegro del .json. No expira como el OAuth.
# Acepta JSON crudo o en base64 si el panel reescapa saltos de línea.
# NUNCA commitees el JSON: va SOLO como variable de entorno.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Credenciales OAuth (solo fallback local, último recurso — expira).
# GOOGLE_CREDENTIALS_PATH=.credentials/credentials.json
# GOOGLE_CREDENTIALS_JSON=
# GOOGLE_TOKEN_JSON=

# ─── Claude API (fallback de lenguaje natural) ────────────────────
#
# console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Seguridad del webhook de Twilio ──────────────────────────────
#
# Auth Token de tu cuenta Twilio (console.twilio.com → Account Info).
# Necesario para validar la firma X-Twilio-Signature de cada mensaje.
TWILIO_AUTH_TOKEN=

# Whitelist de números autorizados. Separados por comas.
# Acepta 'whatsapp:+521...' o solo '+521...'.
# Vacío = no filtra a nadie (inseguro para producción).
NUMEROS_AUTORIZADOS=

# Flags de enforcement (modo log-only por defecto = "0").
#   "0" → registra en logs lo que NO pasaría, pero NO bloquea.
#   "1" → bloquea (403). Activar solo después de observar logs en Railway.
ENFORCE_TWILIO_SIGNATURE=0
ENFORCE_WHITELIST=0

# ─── Twilio — número y cuenta ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Meta WhatsApp Cloud API (alternativa a Twilio) ────────────────
#
# Soporte AÑADIDO sin quitar Twilio: el webhook (POST /webhook) detecta el canal
# por content-type (JSON = Meta, form = Twilio). Para migrar a Meta, configura
# estas tres variables y apunta el webhook de Meta a https://<dominio>/webhook.
# Si NO están definidas, la app arranca igual y sigue operando con Twilio.
#
# Phone Number ID del número de WhatsApp (Meta → WhatsApp → API Setup).
META_PHONE_NUMBER_ID=
# Access Token (System User token permanente; el temporal expira en 24h).
META_ACCESS_TOKEN=
# Token de verificación: string que tú eliges; debe COINCIDIR con el configurado
# en Meta Console al activar el webhook (GET de verificación / hub.verify_token).
META_VERIFY_TOKEN=
# Versión de Graph API (opcional). Default: v21.0. Meta retira cada versión ~2
# años después de publicarla; sube esto cuando salga una nueva sin tocar código.
# META_GRAPH_VERSION=v21.0

# ─── Sincronización automática de Drive ───────────────────────────
# Intervalo en horas. Default: 6.
SYNC_INTERVALO_HORAS=6

# ─── URL pública (links de reportes HTML) ─────────────────────────
# Base pública usada para armar los links de reportes (/reportes/<token>.html).
# En Railway se tomaba de RAILWAY_PUBLIC_DOMAIN (inyectada por Railway). En un
# servidor propio (Hetzner) esa variable NO existe, así que define el dominio
# público aquí; si no, el link saldría como http://localhost:8000 (inservible).
PUBLIC_BASE_URL=https://cesymhvac.com

# ─── Railway (inyectadas automáticamente, no configurar a mano) ───
# RAILWAY_PUBLIC_DOMAIN=tu-app.up.railway.app
# PORT=8000
